# Copy this file to .env.local for local development.
# In production (Vercel), set these under Project Settings -> Environment Variables.

# Neon PostgreSQL connection string (pooled connection recommended).
# Get this from your Neon dashboard -> Connection Details.
# Example: postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Secret used to sign session tokens. Use a long, random value in production,
# e.g. `openssl rand -hex 32`.
JWT_SECRET=

# Cloudinary — used for all file storage (avatars, article images, PDF
# attachments, event/video uploads). Get these from your Cloudinary
# dashboard -> Account Details. All three are required; uploads will fail
# without them.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: used to generate absolute URLs for social share metadata (Open Graph).
# Set this to your deployed domain, e.g. https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# One-time database seeding (only used the very first time the app connects
# to an EMPTY database — see src/lib/server/config/seed.ts).
# ---------------------------------------------------------------------------

# The first administrator account. Required to auto-create an admin on a
# fresh database — if either is left blank, no admin account is seeded and
# you'll need to create one manually (e.g. directly in Neon's SQL editor).
# Change the password after your first login.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# Optional: public "about the club" content shown on the site, seeded once
# into an empty database. Safe to leave blank — the site will just show
# empty/default values until you fill them in from the Admin Dashboard.
SEED_CLUB_NAME=
SEED_CLUB_ARABIC_NAME=
SEED_CONTACT_EMAIL=
SEED_CONTACT_PHONE=
SEED_ADDRESS=
SEED_WHATSAPP_URL=
SEED_TELEGRAM_URL=
SEED_FOUNDER_NAME=
SEED_FOUNDER_TITLE=
SEED_FOUNDER_BIO=
SEED_FOUNDER_IMAGE_URL=
SEED_FOUNDER_MESSAGE=
SEED_MEMBER_NAME=
SEED_MEMBER_AVATAR_URL=
SEED_MEMBER_ACHIEVEMENT=
SEED_MEMBER_BIO=
SEED_MEMBER_MONTH=


